# Required for backend API route
GEMINI_API_KEY=
EXPLORIUM_API_KEY=
EXPLORIUM_BASE_URL=https://api.explorium.ai
EXPLORIUM_MATCH_PATH=/v1/businesses/match
EXPLORIUM_BULK_ENRICH_PATH=/v1/businesses/firmographics/bulk_enrich

# Frontend origin allowed by backend in production
ALLOWED_ORIGIN=

# true/false: use mock Explorium responses for local development
USE_MOCK_EXPLORIUM=true

# Node environment: development/production
NODE_ENV=development
